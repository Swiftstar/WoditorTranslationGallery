   CONTROL 127, -1, STATIC, SS_ICON | WS_CHILD | WS_VISIBLE, 7, 30, 20, 20 
   CONTROL "　歡迎使用 WOLF RPG 編輯器 Ver3！\r\n　由於Ver3已將所有資料文字編碼改為【UTF-8】，\r\n 首先會執行「檔案轉換」。準備好了嗎？\r\n\r\n【將被轉換的檔案】\r\n·Data/BasicData資料夾內的「基本資料(.dat/.project)」\r\n·Data資料夾下所有「地圖檔(.mps)」\r\n·Data資料夾下所有「文字檔(.txt)」\r\n·Data資料夾下所有「CSV檔(.csv)」", -1, STATIC, SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 36, 4, 196, 74 , WS_EX_STATICEDGE
   CONTROL "執行【轉換(資料轉換)】", 1, BUTTON, BS_DEFPUSHBUTTON | BS_MULTILINE | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 39, 130, 86, 31 
   CONTROL "", 1893, EDIT, ES_LEFT | ES_MULTILINE | ES_READONLY | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL | WS_TABSTOP, 241, 18, 196, 174 
   CONTROL "【重要!!】 轉換對象檔案在執行前\r\n會先【備份（儲存）】到【Backup_Before_Ver3】資料夾。\r\n若發生問題請還原這些檔案。", -1, STATIC, SS_CENTER | WS_CHILD | WS_VISIBLE | WS_GROUP, 12, 169, 209, 29 
   CONTROL "取消\r\n(關閉編輯器)", 2, BUTTON, BS_DEFPUSHBUTTON | BS_MULTILINE | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 151, 133, 56, 25 
   CONTROL "【轉換日誌】也會儲存於 Backup_Before_Ver3/ConvertLog.txt", -1, STATIC, SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 235, 5, 204, 12 
   CONTROL "【關於文字檔轉換】\r\n ※不會轉換「Data內的.txt」以外文字檔（例如.log）。請之後自行將該檔案轉成UTF-8。\r\n ※UTF-8的txt檔通常不會轉換，但非UTF-8檔案即使語言不同也可能被強制轉換。", -1, STATIC, SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 19, 80, 213, 43 , WS_EX_STATICEDGE
